# Flask Settings
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-here

# Database Configuration
# Options: mysql or sqlite
DB_TYPE=mysql

# MySQL Settings
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DB=asset_management

# SQLite Settings (Used if DB_TYPE=sqlite or if MySQL fails)
SQLITE_DB_PATH=asset_management.db
